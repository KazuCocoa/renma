{
  "fail_on": "high",
  "format": "text",
  "globs": ["skills/**/SKILL.md", "contexts/**/*.md", "tools/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "dist-test",
    ".git",
    ".github",
    "examples",
    "scripts",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "skill_discovery": {
    "adopted": true
  }
}
